# Godot 4+ specific ignores
.godot/
.godot/imported/
.godot/export.cfg
.godot/export_credentials.cfg
.godot/global_script_class_cache.cfg

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg
/android/

# Imported translations (if they generate files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# System/tool-specific ignores
.DS_Store
Thumbs.db
*.bak
*.tmp
*~

# C# / Visual Studio
.vs/
*.user
*.userprefs
*.sln
*.csproj
obj/
bin/
builds/
Pixbots-Installer.exe

# Rust GDExtension (rust_ext/) - built DLLs are large, platform-specific,
# and regenerable via `cargo build [--release]` in rust_ext/. See
# rust_ext/README.md for build/troubleshooting notes. Anyone pulling this
# repo needs to build once locally before the extension loads - the
# .gdextension file's paths point at these now-ignored locations on purpose.
# Cargo.lock IS committed (cdylib/application target, not a library - locking
# exact dependency versions matters more than it would for a published crate).
rust_ext/target/

# Claude Code session data (worktrees, local settings) - machine-local, can
# be large; never belongs in the repo.
.claude/

# One-off dev/session artifacts
diff.txt
*.patch
CLAUDE_CODE_HANDOFF.md
*.log

# Godot editor binaries / export templates kept locally for headless test
# runs and exports - large, platform-specific, redownloadable, never
# project source.
Godot_v*-stable_*.exe
templates/
templates*.zip
